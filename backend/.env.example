# Copy to .env:  cp .env.example .env
# Or:           make env

ENVIRONMENT=local
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000
# Include every frontend origin that may call the API directly (local + deployed).
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Postgres + pgvector (RAG / quizzes / all app tables)
# Picked by ENVIRONMENT: local → DATABASE_URL_LOCAL, prod|production → DATABASE_URL_PROD
# Local: matches docker-compose.yml (user/password/db = onboard)
DATABASE_URL_LOCAL=postgresql+asyncpg://onboard:onboard@localhost:5432/onboard
# Neon: Dashboard → Connection string, rewrite for asyncpg + ssl:
#   postgresql+asyncpg://USER:PASSWORD@HOST/neondb?ssl=require
# Also run once in Neon SQL Editor: CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL_PROD=

# Optional for basic CRUD; required for LLM / RAG / quiz features
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Clerk (backend token verification — never expose CLERK_SECRET_KEY to the browser)
# Pull with: clerk env pull --app app_3GaM8L4Xmg4VxbHEmKdT1AVWvjf --file .env
CLERK_SECRET_KEY=
CLERK_JWT_KEY=
# Comma-separated browser origins allowed as JWT `azp`. Include every frontend URL that proxies
# tokens (local + Vercel), e.g. http://localhost:3000,https://own-board-frontend.vercel.app
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# Supabase Storage only (doc pack file uploads) — NOT the database (Neon/local is DB)
# Dashboard → Project Settings → API
#   SUPABASE_URL              = Project URL (https://xxxx.supabase.co)
#   SUPABASE_SERVICE_ROLE_KEY = service_role secret (NOT the anon key; server-only, bypasses RLS)
# Dashboard → Storage → create a private bucket named doc-packs (or match the name below)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=doc-packs

# Copy to .env:  cp .env.example .env
# Or:           make env

ENVIRONMENT=local
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Matches docker-compose.yml (user/password/db = onboard)
DATABASE_URL=postgresql+asyncpg://onboard:onboard@localhost:5432/onboard

# Optional for basic CRUD; required later for LLM / RAG / quiz features
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ============================================================================
#  OwnBoard — Backend environment (FastAPI)
# ----------------------------------------------------------------------------
#  Setup:   cp .env.example .env      (or: make env)
#  Loaded by pydantic-settings at startup (onboard/config/settings.py).
#
#  Minimum to boot locally:
#    - DATABASE_URL_LOCAL  (already defaulted for the bundled Postgres — just run `make db-up`)
#    - CLERK_SECRET_KEY + CLERK_JWT_KEY   (every non-health request is auth-verified)
#  Optional locally, but required for their features:
#    - OPENAI_API_KEY .......... quizzes, RAG, "Ask project", skill graph
#    - SUPABASE_* .............. document / project-doc uploads (Docs knowledge base)
# ============================================================================

# ---- Runtime ---------------------------------------------------------------
# ENVIRONMENT selects which DATABASE_URL_* is used: local → _LOCAL, prod/production → _PROD.
ENVIRONMENT=local
# One of DEBUG / INFO / WARNING / ERROR.
LOG_LEVEL=INFO

# ---- API server ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of browser origins allowed to call the API directly (CORS).
# Include every frontend origin — local dev + each deployed URL.
#   e.g. http://localhost:3000,https://own-board-frontend.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Database: Postgres + pgvector -----------------------------------------
# Stores every app table + the vector embeddings for RAG / quizzes / Ask.
#
# LOCAL (default): the bundled Postgres from `make db-up` already matches this
# (user/password/db all = "onboard"). No change needed. Don't also run another
# Postgres on :5432. pgvector is enabled automatically on startup locally.
DATABASE_URL_LOCAL=postgresql+asyncpg://onboard:onboard@localhost:5432/onboard
#
# PROD: a hosted Postgres connection string (used only when ENVIRONMENT=prod).
#   Where to get it: Neon (https://neon.tech) → your project → "Connection string",
#   or Render → your Postgres instance → "External Database URL".
#   Paste it verbatim — the app rewrites the scheme to +asyncpg, strips Neon's
#   channel_binding, and appends ssl=require for you.
#   Example: postgresql://USER:PASSWORD@ep-xxxx.neon.tech/neondb?sslmode=require
#   One-time on a fresh hosted DB, run in the SQL editor:  CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL_PROD=

# ---- OpenAI (embeddings + chat) --------------------------------------------
# Powers embeddings (doc/code chunks), quiz generation, archaeology + "Ask project".
# Basic CRUD works without it; anything LLM/RAG returns errors until it's set.
#   Where to get it: https://platform.openai.com/api-keys → "Create new secret key".
#   Format: sk-...  (keep it secret; billing applies).
OPENAI_API_KEY=
# Defaults are fine; override only if you use different models.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Fast/cheap default; complex "Ask project" questions are routed to the complex model.
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_CHAT_MODEL_COMPLEX=gpt-4.1
# Model for the agentic admin AI Assistant (add member, create hire, assign track, analytics).
# Blank → falls back to OPENAI_CHAT_MODEL_COMPLEX. Bump to a stronger agentic model (e.g. gpt-5.1)
# here — no code change — if the assistant needs more reliability on multi-step actions.
OPENAI_ASSISTANT_MODEL=

# ---- Clerk (authentication — backend token verification) -------------------
# Every non-health request's session token is verified here. Never expose the
# secret key or JWT key to the browser (those are backend-only).
# Fastest way to fill the Clerk vars: `clerk env pull --file .env` (Clerk CLI).
#
#   CLERK_SECRET_KEY — Clerk Dashboard → API keys → "Secret keys".
#     Format: sk_test_... (dev) or sk_live_... (prod).
CLERK_SECRET_KEY=
#   CLERK_JWT_KEY — the PEM public key for networkless JWT verification.
#     Clerk Dashboard → API keys → "Show JWT public key" (copy the PEM, incl.
#     -----BEGIN PUBLIC KEY----- … as a single line). Optional but recommended;
#     without it, tokens are verified via a network call to Clerk each request.
CLERK_JWT_KEY=
#   CLERK_AUTHORIZED_PARTIES — comma-separated browser origins allowed as the
#     token's `azp` claim. Must include every frontend URL that proxies tokens.
#     e.g. http://localhost:3000,https://own-board-frontend.vercel.app
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
#   FRONTEND_BASE_URL — where Clerk sends users after accepting a team invite
#     (redirects to <FRONTEND_BASE_URL>/sign-in).
FRONTEND_BASE_URL=http://localhost:3000

# ---- Supabase Storage (file uploads only — NOT the database) ---------------
# Holds uploaded PDFs for onboarding doc packs and the project Docs knowledge
# base. The DB stays on Postgres/Neon above; Supabase is used purely as a file store.
# Uploads fail until these are set.
#   Where to get them: https://supabase.com → your project →
#     Project Settings → API:
#       SUPABASE_URL              = "Project URL"  (https://xxxx.supabase.co)
#       SUPABASE_SERVICE_ROLE_KEY = the "service_role" secret (NOT the anon key).
#                                   Server-only — it bypasses Row Level Security.
#     Storage → "New bucket" → create a PRIVATE bucket named exactly as below.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=doc-packs

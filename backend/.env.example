# Copy to .env:  cp .env.example .env
# Or:           make env

ENVIRONMENT=local
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Matches docker-compose.yml (user/password/db = onboard)
DATABASE_URL=postgresql+asyncpg://onboard:onboard@localhost:5432/onboard

# Optional for basic CRUD; required later for LLM / RAG / quiz features
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Clerk (backend token verification — never expose CLERK_SECRET_KEY to the browser)
# Pull with: clerk env pull --app app_3GaM8L4Xmg4VxbHEmKdT1AVWvjf --file .env
CLERK_SECRET_KEY=
CLERK_JWT_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# Supabase Storage (doc pack uploads) — Project Settings > API in the Supabase dashboard.
# SUPABASE_SERVICE_ROLE_KEY is server-only: it bypasses RLS, never send it to the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=doc-packs

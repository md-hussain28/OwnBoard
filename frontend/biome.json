{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!!node_modules",
      "!!.impeccable",
      "!!.next",
      "!!storybook-static",
      "!!public/mockServiceWorker.js"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "css": {
    "parser": {
      "cssModules": true,
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "a11y": {
        "useButtonType": "off",
        "noSvgWithoutTitle": "off",
        "useSemanticElements": "off",
        "useKeyWithClickEvents": "off",
        "noLabelWithoutControl": "off",
        "useAriaPropsSupportedByRole": "off",
        "useFocusableInteractive": "off",
        "noStaticElementInteractions": "off"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": {
            "maxAllowedComplexity": 15
          }
        },
        "noExcessiveLinesPerFunction": {
          "level": "warn",
          "options": {
            "maxLines": 80,
            "skipBlankLines": true
          }
        },
        "noUselessStringConcat": "warn",
        "noUselessTernary": "warn"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn",
        "useHookAtTopLevel": "error",
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn"
      },
      "performance": {
        "noAccumulatingSpread": "warn",
        "noBarrelFile": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "error"
      },
      "suspicious": {
        "noArrayIndexKey": "off",
        "noExplicitAny": "off",
        "noDocumentCookie": "off",
        "noConsole": "warn",
        "noDebugger": "error"
      },
      "style": {
        "noNonNullAssertion": "off",
        "noExcessiveLinesPerFile": {
          "level": "error",
          "options": {
            "maxLines": 500,
            "skipBlankLines": true
          }
        },
        "noDefaultExport": "warn",
        "noNestedTernary": "warn",
        "useCollapsedElseIf": "warn",
        "useFilenamingConvention": {
          "level": "warn",
          "options": {
            "strictCase": true,
            "requireAscii": true,
            "filenameCases": ["kebab-case", "camelCase"]
          }
        },
        "useSelfClosingElements": "warn",
        "useTemplate": "warn",
        "useObjectSpread": "warn",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": [
                  "@/components/**",
                  "@/ui/**",
                  "@/hooks/**",
                  "@/lib/**",
                  "@/schemas/**",
                  "@/services/**",
                  "@/stores/**",
                  "@/providers/**",
                  "@/constants/**",
                  "@/types/**",
                  "!@/components/admin",
                  "!@/components/ask",
                  "!@/components/brand",
                  "!@/components/chat",
                  "!@/components/dashboard",
                  "!@/components/doc-pack",
                  "!@/components/expert",
                  "!@/components/home",
                  "!@/components/home/admin",
                  "!@/components/layout",
                  "!@/components/marketing",
                  "!@/components/onboarding",
                  "!@/components/project",
                  "!@/components/repo",
                  "!@/components/shared",
                  "!@/components/skill-graph",
                  "!@/components/team",
                  "!@/components/tour",
                  "!@/ui",
                  "!@/ui/ai-elements",
                  "!@/ui/sidebar",
                  "!@/hooks",
                  "!@/hooks/queries",
                  "!@/hooks/queries/admin",
                  "!@/hooks/queries/ask",
                  "!@/hooks/queries/chat",
                  "!@/hooks/queries/dashboard",
                  "!@/hooks/queries/doc-pack",
                  "!@/hooks/queries/employee",
                  "!@/hooks/queries/expert",
                  "!@/hooks/queries/ingest-key",
                  "!@/hooks/queries/me",
                  "!@/hooks/queries/notification",
                  "!@/hooks/queries/org-domain",
                  "!@/hooks/queries/pack-assignment",
                  "!@/hooks/queries/project",
                  "!@/hooks/queries/quiz",
                  "!@/hooks/queries/quiz-domain",
                  "!@/hooks/queries/repo",
                  "!@/hooks/queries/skill-graph",
                  "!@/lib",
                  "!@/lib/api",
                  "!@/lib/tour",
                  "!@/lib/api/proxy",
                  "!@/lib/api/backend-client",
                  "!@/lib/platform-admin",
                  "!@/schemas",
                  "!@/services",
                  "!@/stores",
                  "!@/providers",
                  "!@/constants",
                  "!@/types"
                ],
                "message": "Import from the folder's barrel index (e.g. \"@/ui\", \"@/components/shared\", \"@/hooks/queries/project\"), not a file inside it. Each module folder's index.ts is its public API."
              }
            ]
          }
        }
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/ui/**"],
      "linter": {
        "rules": {
          "a11y": {
            "useFocusableInteractive": "off",
            "useAriaPropsSupportedByRole": "off",
            "noStaticElementInteractions": "off"
          },
          "complexity": {
            "noImportantStyles": "off",
            "noExcessiveLinesPerFunction": "off",
            "noExcessiveCognitiveComplexity": "off"
          },
          "style": {
            "noExcessiveLinesPerFile": "off",
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/page.tsx",
        "**/layout.tsx",
        "**/loading.tsx",
        "**/error.tsx",
        "**/not-found.tsx",
        "**/template.tsx",
        "**/default.tsx",
        "**/middleware.ts",
        "**/opengraph-image.tsx",
        "**/icon.tsx",
        "**/*.config.ts",
        "**/*.config.mjs",
        "**/*.config.js"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": ["**/error.tsx", "**/global-error.tsx"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          },
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.stories.tsx", ".storybook/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noConsole": "off"
          },
          "style": {
            "noDefaultExport": "off",
            "noExcessiveLinesPerFile": "off"
          },
          "complexity": {
            "noExcessiveLinesPerFunction": "off",
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    }
  ]
}
